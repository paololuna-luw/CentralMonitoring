{
    "ConnectionStrings": {
        "Default": ""
    },
    "ApiKey": "",
    "Agent": {
        "AutoRules": {
            "Enabled": true,
            "Patterns": [
                { "MetricKey": "cpu_usage_pct", "Operator": ">", "Threshold": 85, "WindowMinutes": 3, "Severity": "Critical", "Enabled": true },
                { "MetricKey": "mem_used_pct", "Operator": ">", "Threshold": 90, "WindowMinutes": 3, "Severity": "Critical", "Enabled": true },
                { "MetricKey": "disk_used_pct", "Operator": ">", "Threshold": 92, "WindowMinutes": 5, "Severity": "Critical", "Enabled": true },
                { "MetricKey": "net_rx_errors", "Operator": ">", "Threshold": 0, "WindowMinutes": 5, "Severity": "Warning", "Enabled": true },
                { "MetricKey": "net_tx_errors", "Operator": ">", "Threshold": 0, "WindowMinutes": 5, "Severity": "Warning", "Enabled": true }
            ],
            "CriticalWindowsServices": [ "Spooler", "wuauserv" ],
            "CriticalLinuxSystemdUnits": [ "sshd", "cron" ],
            "ServiceRule": {
                "Enabled": true,
                "WindowMinutes": 2,
                "Severity": "Critical"
            }
        }
    },
    "Snmp": {
        "Metrics": [
            { "Key": "snmp_sysUpTime", "Oid": "1.3.6.1.2.1.1.3.0" },
            { "Key": "snmp_ifInOctets_1", "Oid": "1.3.6.1.2.1.2.2.1.10.1" },
            { "Key": "snmp_ifOutOctets_1", "Oid": "1.3.6.1.2.1.2.2.1.16.1" },
            { "Key": "snmp_ifOperStatus_1", "Oid": "1.3.6.1.2.1.2.2.1.8.1" },
            { "Key": "snmp_ifInErrors_1", "Oid": "1.3.6.1.2.1.2.2.1.14.1" },
            { "Key": "snmp_ifOutErrors_1", "Oid": "1.3.6.1.2.1.2.2.1.20.1" },
            { "Key": "snmp_ifAdminStatus_1", "Oid": "1.3.6.1.2.1.2.2.1.7.1" },
            { "Key": "snmp_hrProcessorLoad_1", "Oid": "1.3.6.1.2.1.25.3.3.1.2.1" },
            { "Key": "snmp_hrProcessorLoad_2", "Oid": "1.3.6.1.2.1.25.3.3.1.2.2" }
        ],
        "AutoRules": {
            "InterfaceDown": true,
            "Patterns": [
                {
                    "MetricKey": "snmp_ifOperStatus_{ifIndex}",
                    "Operator": "!=",
                    "Threshold": 1,
                    "WindowMinutes": 2,
                    "Severity": "Critical",
                    "IfIndex": 1,
                    "Enabled": true
                },
                {
                    "MetricKey": "snmp_ifInErrors_{ifIndex}",
                    "Operator": ">",
                    "Threshold": 0,
                    "WindowMinutes": 5,
                    "Severity": "Warning",
                    "IfIndex": 1,
                    "Enabled": true
                },
                {
                    "MetricKey": "snmp_ifOutErrors_{ifIndex}",
                    "Operator": ">",
                    "Threshold": 0,
                    "WindowMinutes": 5,
                    "Severity": "Warning",
                    "IfIndex": 1,
                    "Enabled": true
                }
            ]
        }
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.File" ],
        "MinimumLevel": "Information",
        "WriteTo": [
            { "Name": "File", "Args": { "path": "logs/api-.log", "rollingInterval": "Day", "shared": true, "restrictedToMinimumLevel": "Information" } }
        ],
        "Enrich": [ "FromLogContext" ]
    },
    "ConsoleLogging": {
        "Enabled": true
    }
}
