{
  "ConnectionStrings": {
    "Default": "Host=127.0.0.1;Port=5432;Database=central_monitoring;Username=central_app;Password=CHANGE_ME"
  },
  "Snmp": {
    "PollIntervalSeconds": 15,
    "TimeoutMs": 5000,
    "Retries": 2,
    "GraceEnabled": false,
    "MaxConsecutiveFailures": 120
  },
  "Retention": {
    "Enabled": false,
    "MetricsDays": 30,
    "AlertsDays": 90,
    "RunIntervalMinutes": 60,
    "BatchSize": 10000
  },
  "Cloud": {
    "Enabled": true,
    "BaseUrl": "https://centralmonitoring-cloudapi.example.com",
    "InstanceId": "00000000-0000-0000-0000-000000000000",
    "InstanceName": "Central Cliente 01",
    "OrganizationName": "Cliente 01",
    "OrganizationSlug": "cliente-01",
    "Description": "Central instalada en cliente 01",
    "SyncApiKey": "OPTIONAL_IF_REQUIRED",
    "SyncIntervalSeconds": 60
  },
  "Alerting": {
    "WebhookUrl": "",
    "MaxDispatchAttempts": 3
  },
  "ConsoleLogging": {
    "Enabled": false
  }
}
